{
  "permissions": {
    "allow": [
      "Agent(ralph_stage1_evaluator)",
      "Agent(ralph_stage1_qa)",
      "Agent(ralph_stage2_builder)",
      "Agent(ralph_stage2_qa)",
      "Agent(browser_subagent)",
      "Agent(prd_writer_agent)",
      "Agent(gsafe_manager)"
    ],
    "ask": [
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git rebase *)",
      "Bash(git reset --hard *)",
      "Bash(git checkout -- *)",
      "Bash(git clean *)",
      "Bash(git branch -D *)",
      "Bash(sudo rm *)",
      "Bash(chmod 777 *)"
    ],
    "deny": [
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ]
  }
}
